# ── Supabase ────────────────────────────────────────────────────────────────
# Optional. Without these the app runs in guest/local-storage mode (no saved or
# shared results). Provide all three to enable persistence and share links.
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-only. Used by API routes for privileged writes. If omitted, the server
# Supabase client is disabled (routes degrade gracefully) rather than silently
# falling back to the anon key. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=optional-service-role-key

# ── OpenRouter (AI explanation) ───────────────────────────────────────────────
# Optional. Without OPENROUTER_API_KEY the AI explanation route returns a
# specialty-aware fallback instead of a generated summary.
# Get a key at https://openrouter.ai/keys . Pick any model id from
# https://openrouter.ai/models (append :free for the free tier of some models).
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct

# ── Site ──────────────────────────────────────────────────────────────────────
# Required. Absolute base URL, used for metadata, sitemap, and share links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Rate limiting (optional, recommended for production) ──────────────────────
# When set, the API rate limiter uses Upstash Redis (durable across serverless
# instances). When absent, it falls back to an in-memory limiter suitable only
# for local development.
# UPSTASH_REDIS_REST_URL=your-upstash-redis-url
# UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token
